# ---- MongoDB Atlas ----
# Get this from Atlas: Cluster -> Connect -> Drivers -> Node.js
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ayurvedic_diet?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/ayurvedic_diet?retryWrites=true&w=majority

# ---- Server ----
PORT=5000

# ---- Translation (MyMemory) ----
# Optional. Adding an email RAISES the free daily quota (50k -> ~50k+ words/day).
# Leave blank to use the anonymous tier (lower quota).
MYMEMORY_EMAIL=

# CORS origin for your frontend (use * during local dev)
CLIENT_ORIGIN=*

# ---- Auth (Google SSO) ----
# 1) Go to https://console.cloud.google.com/apis/credentials
# 2) Create OAuth client ID -> Application type: "Web application"
# 3) Authorized JavaScript origins: http://localhost:5000 (and your prod URL)
# 4) Paste the Client ID below (looks like 1234567890-abcdef.apps.googleusercontent.com)
GOOGLE_CLIENT_ID=

# Secret used to sign our own session tokens. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
